{
  "name": "cloud-stack-notes",
  "version": "0.1.0",
  "private": true,
  "description": "Hugo powered Chinese technical blog with Pagefind local search.",
  "scripts": {
    "dev": "hugo server --bind 0.0.0.0 --baseURL http://localhost:1313 --disableFastRender",
    "build": "hugo --gc --minify && pagefind --site public --output-subdir pagefind",
    "build:hugo": "hugo --gc --minify",
    "index": "pagefind --site public --output-subdir pagefind",
    "serve:public": "pagefind --site public --serve"
  },
  "devDependencies": {
    "pagefind": "^1.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
